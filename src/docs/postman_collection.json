{
	"info": {
		"_postman_id": "7bf3b3a3-bcf2-49df-8b2b-0ff6960dcdb1",
		"name": "Smart Attendance System - Complete",
		"description": "Full Postman API Collection for testing Phase 1 & Phase 2 of the Smart Attendance System.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register Admin User",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type","value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"Super Admin\",\n  \"email\": \"admin@university.edu\",\n  \"password\": \"Password123\",\n  \"role\": \"Admin\",\n  \"department\": \"IT\",\n  \"employeeId\": \"ADMIN001\"\n}"
						},
						"url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"]}
					}
				},
				{
					"name": "Register Student",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type","value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"student.john@university.edu\",\n  \"password\": \"Password123\",\n  \"role\": \"Student\",\n  \"department\": \"Computer Science\",\n  \"course\": \"B.Tech CSE\",\n  \"semester\": 4,\n  \"studentId\": \"STUD123456\"\n}"
						},
						"url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"]}
					}
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data.token) {",
									"    pm.environment.set(\"jwt_token\", jsonData.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type","value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@university.edu\",\n  \"password\": \"Password123\"\n}"
						},
						"url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"]}
					}
				},
				{
					"name": "Get Profile",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "GET",
						"url": {"raw": "{{base_url}}/api/auth/profile", "host": ["{{base_url}}"], "path": ["api","auth","profile"]}
					}
				}
			]
		},
		{
			"name": "2. Location Zones (Phase 2)",
			"item": [
				{
					"name": "Create Location Zone",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    pm.environment.set(\"zone_id\", jsonData.data._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "POST",
						"header": [{"key": "Content-Type","value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"zoneName\": \"Main Campus\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090,\n  \"radiusInMeters\": 50\n}"
						},
						"url": {"raw": "{{base_url}}/api/zones", "host": ["{{base_url}}"], "path": ["api","zones"]}
					}
				}
			]
		},
		{
			"name": "3. QR Sessions",
			"item": [
				{
					"name": "Create QR Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    pm.environment.set(\"qr_token\", jsonData.data.qrData);",
									"    pm.environment.set(\"session_id\", jsonData.data.session._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "POST",
						"header": [{"key": "Content-Type","value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sessionName\": \"DBMS Lecture 12\",\n  \"subject\": \"Database Management Systems\",\n  \"expiryMinutes\": 5,\n  \"locationZone\": \"{{zone_id}}\"\n}"
						},
						"url": {"raw": "{{base_url}}/api/qr/create-session", "host": ["{{base_url}}"], "path": ["api","qr","create-session"]}
					}
				},
				{
					"name": "Get Active Sessions",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "GET",
						"url": {"raw": "{{base_url}}/api/qr/active", "host": ["{{base_url}}"], "path": ["api","qr","active"]}
					}
				},
				{
					"name": "Terminate Session",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "DELETE",
						"url": {"raw": "{{base_url}}/api/qr/{{session_id}}", "host": ["{{base_url}}"], "path": ["api","qr","{{session_id}}"]}
					}
				}
			]
		},
		{
			"name": "4. Attendance Processing",
			"item": [
				{
					"name": "Mark QR Attendance (With GPS)",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "POST",
						"header": [{"key": "Content-Type","value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"qrToken\": \"{{qr_token}}\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090\n}"
						},
						"url": {"raw": "{{base_url}}/api/attendance/mark", "host": ["{{base_url}}"], "path": ["api","attendance","mark"]}
					}
				},
				{
					"name": "Get My Attendance History",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "GET",
						"url": {"raw": "{{base_url}}/api/attendance/history", "host": ["{{base_url}}"], "path": ["api","attendance","history"]}
					}
				},
				{
					"name": "Get All Records (Admin)",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "GET",
						"url": {"raw": "{{base_url}}/api/attendance/all", "host": ["{{base_url}}"], "path": ["api","attendance","all"]}
					}
				}
			]
		},
		{
			"name": "5. Dashboard & Reports (Phase 2)",
			"item": [
				{
					"name": "Dashboard Stats",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "GET",
						"url": {"raw": "{{base_url}}/api/dashboard/stats", "host": ["{{base_url}}"], "path": ["api","dashboard","stats"]}
					}
				},
				{
					"name": "Daily Report",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token","value": "{{jwt_token}}","type": "string"}]},
						"method": "GET",
						"url": {"raw": "{{base_url}}/api/reports/daily", "host": ["{{base_url}}"], "path": ["api","reports","daily"]}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000",
			"type": "string"
		}
	]
}
